#!/usr/bin/env bash
set -euo pipefail

DEPLOY_DIR="/opt/sentinel/deploy"
LAUNCHER="${DEPLOY_DIR}/sentinel-install-update-launcher.sh"

if [[ ! -f "${LAUNCHER}" ]]; then
  echo "Sentinel install/update launcher not found: ${LAUNCHER}" >&2
  echo "Reinstall sentinel package." >&2
  exit 1
fi

exec bash "${LAUNCHER}" "$@"
