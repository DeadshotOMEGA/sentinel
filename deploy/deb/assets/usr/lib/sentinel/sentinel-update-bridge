#!/usr/bin/env python3
from __future__ import annotations

import argparse
import fcntl
import json
import logging
import os
import socket
import struct
import subprocess
import sys
from pathlib import Path
from typing import Any

CURRENT_DIR = Path(__file__).resolve().parent
if str(CURRENT_DIR) not in sys.path:
    sys.path.insert(0, str(CURRENT_DIR))

from sentinel_update_common import (
    APPLIANCE_ENV_PATH,
    CURRENT_JOB_PATH,
    JOB_ID_PATTERN,
    JOBS_DIR,
    LOCK_PATH,
    TRACE_LOG_PATH,
    VERSION_PATTERN,
    apply_job_progress,
    ensure_job_progress,
    append_trace_line,
    archive_and_reset_trace,
    ensure_runtime_directories,
    is_terminal_job,
    is_terminal_status,
    load_appliance_state,
    read_env_file,
    read_json_file,
    utc_now,
    write_json_file,
)

LOGGER = logging.getLogger("sentinel-update-bridge")
MAX_REQUEST_BYTES = 4096
BACKEND_UID = int(os.environ.get("SENTINEL_BACKEND_SERVICE_UID", "10001"))
BACKEND_GID = int(os.environ.get("SENTINEL_BACKEND_SERVICE_GID", "10001"))
POLKIT_ACTION_ID = os.environ.get(
    "SENTINEL_UPDATE_POLKIT_ACTION_ID", "com.deadshotomega.sentinel.update.start"
)
UPDATER_UNIT = os.environ.get("SENTINEL_UPDATER_UNIT", "sentinel-updater.service")
SOCKET_PATH = Path(os.environ.get("SENTINEL_UPDATE_BRIDGE_SOCKET_PATH", "/run/sentinel/update-bridge.sock"))
BRIDGE_COMPONENT = "bridge"

ALLOWED_KEYS = {
    "jobId",
    "targetVersion",
    "requestedByAccountLevel",
    "requestedByMemberId",
    "requestedByMemberName",
    "requestedFromIp",
}


class BridgeError(RuntimeError):
    def __init__(self, message: str, *, status: int = 400) -> None:
        super().__init__(message)
        self.status = status


def trace(level: str, message: str) -> None:
    append_trace_line(BRIDGE_COMPONENT, level, message)


def trace_if_exists(level: str, message: str) -> None:
    if TRACE_LOG_PATH.exists():
        trace(level, message)


def configure_logging() -> None:
    logging.basicConfig(
        level=os.environ.get("LOG_LEVEL", "INFO").upper(),
        format="[sentinel-update-bridge] %(message)s",
        stream=sys.stdout,
    )


def get_listener(socket_path: Path) -> socket.socket:
    listen_fds = int(os.environ.get("LISTEN_FDS", "0"))
    if listen_fds >= 1:
        return socket.fromfd(3, socket.AF_UNIX, socket.SOCK_STREAM)

    socket_path.parent.mkdir(parents=True, exist_ok=True)
    if socket_path.exists():
        socket_path.unlink()

    listener = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    listener.bind(str(socket_path))
    listener.listen()
    return listener


def get_peer_credentials(connection: socket.socket) -> tuple[int, int, int]:
    raw = connection.getsockopt(socket.SOL_SOCKET, socket.SO_PEERCRED, struct.calcsize("3i"))
    return struct.unpack("3i", raw)


def receive_payload(connection: socket.socket) -> dict[str, Any]:
    chunks: list[bytes] = []
    received = 0

    while True:
        chunk = connection.recv(1024)
        if not chunk:
            break
        chunks.append(chunk)
        received += len(chunk)
        if received > MAX_REQUEST_BYTES:
            raise BridgeError("Request payload exceeds maximum size.", status=413)

    if not chunks:
        raise BridgeError("Empty update request.", status=400)

    try:
        payload = json.loads(b"".join(chunks).decode("utf-8"))
    except json.JSONDecodeError as error:
        raise BridgeError(f"Invalid JSON payload: {error.msg}", status=400) from error

    if not isinstance(payload, dict):
        raise BridgeError("Update request must be a JSON object.", status=400)

    unexpected = set(payload) - ALLOWED_KEYS
    if unexpected:
        raise BridgeError(
            f"Unexpected request fields: {', '.join(sorted(unexpected))}.", status=400
        )

    required = {"jobId", "targetVersion", "requestedByMemberId", "requestedByMemberName"}
    missing = required - set(payload)
    if missing:
        raise BridgeError(f"Missing request fields: {', '.join(sorted(missing))}.", status=400)

    job_id = str(payload.get("jobId", "")).strip()
    target_version = str(payload.get("targetVersion", "")).strip()
    member_id = str(payload.get("requestedByMemberId", "")).strip()
    member_name = str(payload.get("requestedByMemberName", "")).strip()
    requester_level = payload.get("requestedByAccountLevel", None)
    requester_ip = payload.get("requestedFromIp", None)

    if not JOB_ID_PATTERN.match(job_id):
        raise BridgeError("Invalid jobId.", status=400)
    if not VERSION_PATTERN.match(target_version):
        raise BridgeError("Invalid targetVersion.", status=400)
    if not member_id or len(member_id) > 128:
        raise BridgeError("Invalid requestedByMemberId.", status=400)
    if not member_name or len(member_name) > 160:
        raise BridgeError("Invalid requestedByMemberName.", status=400)
    if requester_level is not None and not isinstance(requester_level, int):
        raise BridgeError("Invalid requestedByAccountLevel.", status=400)
    if requester_ip is not None and (not isinstance(requester_ip, str) or len(requester_ip) > 64):
        raise BridgeError("Invalid requestedFromIp.", status=400)

    return {
        "jobId": job_id,
        "targetVersion": target_version,
        "requestedByMemberId": member_id,
        "requestedByMemberName": member_name,
        "requestedByAccountLevel": requester_level,
        "requestedFromIp": requester_ip,
    }


def current_job_is_active() -> bool:
    job = read_json_file(CURRENT_JOB_PATH)
    return not is_terminal_job(job)


def run_polkit_check() -> None:
    result = subprocess.run(
        [
            "pkcheck",
            "--action-id",
            POLKIT_ACTION_ID,
            "--process",
            str(os.getpid()),
        ],
        capture_output=True,
        text=True,
        check=False,
        timeout=10,
    )
    if result.returncode != 0:
        stderr = (result.stderr or result.stdout or "").strip() or "polkit check failed"
        raise BridgeError(f"Authorization failed: {stderr}", status=403)


def start_updater_unit() -> None:
    trace("info", f"Starting updater unit {UPDATER_UNIT}.")
    result = subprocess.run(
        ["systemctl", "start", "--no-block", UPDATER_UNIT],
        capture_output=True,
        text=True,
        check=False,
        timeout=15,
    )
    if result.returncode != 0:
        stderr = (result.stderr or result.stdout or "").strip() or "systemctl start failed"
        trace("error", f"Updater unit failed to start: {stderr}")
        raise BridgeError(f"Failed to start updater service: {stderr}", status=500)
    trace("info", f"Updater unit {UPDATER_UNIT} was handed off successfully.")


def persist_initial_job(payload: dict[str, Any]) -> dict[str, Any]:
    lock_handle = LOCK_PATH.open("a+", encoding="utf-8")
    try:
        fcntl.flock(lock_handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError as error:
        trace_if_exists("warning", "Rejected a new update request because another updater operation already holds the lock.")
        raise BridgeError("An update or updater maintenance task is already in progress.", status=409) from error

    try:
        if current_job_is_active():
            trace_if_exists("warning", "Rejected a new update request because another update job is already active.")
            raise BridgeError("An update is already in progress.", status=409)

        state = load_appliance_state()
        appliance_env = read_env_file(APPLIANCE_ENV_PATH)
        current_version = appliance_env.get("SENTINEL_VERSION") or state.get("currentVersion")
        job = {
            "schemaVersion": 2,
            "operation": "update",
            "source": "frontend-admin",
            "jobId": payload["jobId"],
            "status": "requested",
            "message": "Update request accepted and waiting for the updater service.",
            "requestedAt": utc_now(),
            "startedAt": None,
            "finishedAt": None,
            "durationSeconds": None,
            "currentVersion": current_version or None,
            "latestVersion": None,
            "targetVersion": payload["targetVersion"],
            "requestedVersion": payload["targetVersion"],
            "attemptedVersion": payload["targetVersion"],
            "previousVersion": current_version or None,
            "lastKnownGoodVersion": str(state.get("lastKnownGoodVersion") or current_version or "") or None,
            "lastFailedVersion": str(state.get("lastFailedVersion") or "") or None,
            "failureSummary": None,
            "rollbackAttempted": False,
            "rollbackResult": "not_needed",
            "restoreRecommended": False,
            "healthzPassed": None,
            "requestedBy": {
                "memberId": payload["requestedByMemberId"],
                "memberName": payload["requestedByMemberName"],
                "accountLevel": payload["requestedByAccountLevel"],
                "fromIp": payload["requestedFromIp"],
            },
            "requestedConfig": {},
            "artifact": {},
            "backup": {"attempted": False, "succeeded": False, "paths": [], "manifests": []},
            "rollback": {
                "attempted": False,
                "result": "not_needed",
                "currentVersion": current_version or None,
            },
            "migration": {"mode": None, "status": "pending"},
            "network": {"status": "pending", "message": "Not started."},
            "warnings": [],
            "phase": {
                "key": "prepare_update",
                "label": "Prepare update",
                "description": "Confirm the requested release and gather trusted metadata.",
                "kind": "primary",
                "order": 1,
                "total": 5,
            },
            "checkpoint": {
                "key": "request_accepted",
                "label": "Update request accepted",
                "detail": "Update request accepted and waiting for the updater service.",
            },
            "tracePath": str(TRACE_LOG_PATH),
            "jobLogPath": None,
            "logPath": None,
            "nextAction": "Wait for the updater to complete or inspect the active update trace.",
        }
        write_json_file(JOBS_DIR / f"{payload['jobId']}.json", job, mode=0o644)
        write_json_file(CURRENT_JOB_PATH, job, mode=0o644)
        trace(
            "info",
            "Persisted new update job "
            f"{payload['jobId']} targeting {payload['targetVersion']} for {payload['requestedByMemberName']}.",
        )
        return job
    finally:
        fcntl.flock(lock_handle.fileno(), fcntl.LOCK_UN)
        lock_handle.close()


def mark_job_failed(job: dict[str, Any], message: str) -> dict[str, Any]:
    failed_job = {
        **job,
        "status": "failed",
        "message": message,
        "failureSummary": message,
        "finishedAt": utc_now(),
    }
    apply_job_progress(
        failed_job,
        phase_key="recovery",
        checkpoint_key="update_failed",
        checkpoint_detail=message,
    )
    ensure_job_progress(failed_job)
    write_json_file(JOBS_DIR / f"{job['jobId']}.json", failed_job, mode=0o644)
    write_json_file(CURRENT_JOB_PATH, failed_job, mode=0o644)
    trace("error", f"Marked update job {job['jobId']} as failed before updater handoff: {message}")
    return failed_job


def write_response(connection: socket.socket, payload: dict[str, Any], status: int = 200) -> None:
    response = json.dumps({"status": status, **payload}).encode("utf-8")
    connection.sendall(response)


def handle_connection(connection: socket.socket) -> None:
    pid, uid, gid = get_peer_credentials(connection)
    LOGGER.info("Received bridge connection from pid=%s uid=%s gid=%s", pid, uid, gid)

    if uid != BACKEND_UID or gid != BACKEND_GID:
        raise BridgeError("Caller is not permitted to access the update bridge.", status=403)

    payload = receive_payload(connection)
    if current_job_is_active():
        trace_if_exists(
            "warning",
            f"Rejected duplicate update request for {payload['targetVersion']} because an active job exists.",
        )
        raise BridgeError("An update is already in progress.", status=409)

    run_polkit_check()
    archive_and_reset_trace(
        BRIDGE_COMPONENT,
        (
            "Accepted a new Sentinel update request for "
            f"{payload['targetVersion']} from {payload['requestedByMemberName']}."
        ),
        archive_suffix=payload["jobId"],
        session_job_id=payload["jobId"],
    )
    trace("info", "Reset the active update trace log for the newly accepted update run.")
    trace("info", f"Received bridge connection from pid={pid} uid={uid} gid={gid}.")
    trace(
        "info",
        "Validated request payload for job "
        f"{payload['jobId']} targeting {payload['targetVersion']} from {payload['requestedByMemberName']}.",
    )
    trace("info", "Polkit authorization succeeded for the update request.")
    job = persist_initial_job(payload)
    try:
        start_updater_unit()
    except BridgeError as error:
        mark_job_failed(job, str(error))
        raise
    trace("info", f"Bridge accepted update job {job['jobId']} and returned HTTP 202 to the backend.")
    write_response(
        connection,
        {
            "success": True,
            "message": "System update request accepted.",
            "job": job,
        },
        status=202,
    )


def serve_forever(listener: socket.socket) -> None:
    while True:
        connection, _ = listener.accept()
        try:
            handle_connection(connection)
        except BridgeError as error:
            LOGGER.warning("%s", error)
            trace_if_exists("warning", f"Bridge request failed with status {error.status}: {error}")
            try:
                write_response(
                    connection,
                    {"success": False, "message": str(error)},
                    status=error.status,
                )
            except OSError:
                LOGGER.warning("Unable to write bridge error response back to caller.")
                trace_if_exists("warning", "Unable to write bridge error response back to the caller socket.")
        except Exception as error:  # noqa: BLE001
            LOGGER.exception("Unhandled bridge error")
            trace_if_exists("error", f"Unhandled bridge error: {error}")
            try:
                write_response(
                    connection,
                    {"success": False, "message": f"Unhandled bridge error: {error}"},
                    status=500,
                )
            except OSError:
                LOGGER.warning("Unable to write bridge failure response back to caller.")
                trace_if_exists("warning", "Unable to write bridge failure response back to the caller socket.")
        finally:
            connection.close()


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Sentinel update bridge")
    parser.add_argument("--socket", default=str(SOCKET_PATH))
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    configure_logging()
    ensure_runtime_directories()
    socket_path = Path(args.socket)
    listener = get_listener(socket_path)
    LOGGER.info("Listening for update requests on %s", socket_path)
    serve_forever(listener)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
