        normalize_version_tag(str(state.get("currentVersion", ""))) or "",
        normalize_version_tag(str(state.get("lastKnownGoodVersion", ""))) or "",
        normalize_version_tag(str(state.get("lastAttemptedVersion", ""))) or "",
    }
    return {value for value in versions if value}


def latest_backup_size_bytes() -> int:
    latest_size = 0
    if not BACKUPS_DIR.exists():
        return latest_size

    for path in BACKUPS_DIR.rglob("*"):
        if path.is_file():
            try:
                latest_size = max(latest_size, path.stat().st_size)
            except OSError:
                continue
    return latest_size


def disk_usage_available(path: Path) -> int:
    try:
        return shutil.disk_usage(path).free
    except FileNotFoundError:
        return shutil.disk_usage(path.parent).free


def ensure_free_space(path: Path, required_bytes: int, *, label: str) -> None:
    available_bytes = disk_usage_available(path)
    if available_bytes < required_bytes:
        raise UpdaterError(
            "staging",
            f"Insufficient free space for {label}: need {humanize_bytes(required_bytes)}, "
            f"have {humanize_bytes(available_bytes)} at {path}.",
        )


def report_result_for_job(job: dict[str, Any]) -> str | None:
    status = str(job.get("status", "")).strip()
    if status == "completed":
        return "degraded" if job.get("warnings") else "success"
    if status == "rolled_back":
        return "rolled_back"
    if status in {"failed", "rollback_attempted"}:
        return "failed"
    return None


def report_path_for_job(job: dict[str, Any]) -> Path:
    return JOBS_DIR / f"{job['jobId']}.json"


def update_report_metadata(job: dict[str, Any]) -> None:
    job["schemaVersion"] = REPORT_SCHEMA_VERSION
    job["tracePath"] = active_trace_path()
    ensure_job_progress(job)
    if isinstance(job.get("jobLogPath"), str):
        job["logPath"] = job.get("jobLogPath")
    result = report_result_for_job(job)
    if result is not None:
        job["result"] = result
    duration = duration_seconds(
        job.get("startedAt") if isinstance(job.get("startedAt"), str) else None,
        job.get("finishedAt") if isinstance(job.get("finishedAt"), str) else None,
    )
    if duration is not None:
        job["durationSeconds"] = duration


def print_report_summary(report: dict[str, Any]) -> int:
    operation = str(report.get("operation", "unknown")).strip() or "unknown"
    status = str(report.get("status", "unknown")).strip() or "unknown"
    result = str(report.get("result", status)).strip() or status
    requested = str(report.get("requestedVersion", "")).strip() or "n/a"
    attempted = str(report.get("attemptedVersion", "")).strip() or "n/a"
    current = str(report.get("lastKnownGoodVersion", "")).strip() or "n/a"
    backup_created = "yes" if report.get("backup", {}).get("succeeded") else "no"
    health_passed = report.get("healthzPassed")
    health_text = "n/a" if health_passed is None else ("passed" if health_passed else "failed")
    print(f"Operation: {operation}")
    print(f"Result: {result}")
    print(f"Status: {status}")
    print(f"Requested version: {requested}")
    print(f"Attempted version: {attempted}")
    print(f"Last known good version: {current}")
    print(f"Backup created: {backup_created}")
    print(f"Health check: {health_text}")
    if isinstance(report.get("logPath"), str):
        print(f"Log path: {report['logPath']}")
    if isinstance(report.get("tracePath"), str):
        print(f"Trace path: {report['tracePath']}")
    if isinstance(report.get("nextAction"), str) and report["nextAction"].strip():
        print(f"Next action: {report['nextAction']}")
    return 0


