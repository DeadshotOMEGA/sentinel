def rollback(job: dict[str, Any], previous_artifact: dict[str, str], job_logger: JobLogger) -> None:
    job["rollbackAttempted"] = True
    job.setdefault("rollback", {})
    job["rollback"]["attempted"] = True
    job["rollback"]["targetVersion"] = previous_artifact["version"]
    trace("warning", f"Starting rollback to {previous_artifact['version']}.")
    update_job(
        job,
        status="rollback_attempted",
        message=f"Attempting rollback to {previous_artifact['version']}.",
        job_logger=job_logger,
        phase_key="recovery",
        checkpoint_key="attempting_rollback",
    )

    previous_state = build_runtime_state(load_appliance_state(), job)
    install_deb(Path(previous_artifact["debPath"]), job_logger)
    update_job(
        job,
        status="rollback_attempted",
        message="Pulling container images for rollback.",
        job_logger=job_logger,
        phase_key="recovery",
        checkpoint_key="attempting_rollback",
    )
    pull_stack_images(previous_state, job_logger, version_override=previous_artifact["version"])
    update_job(
        job,
        status="rollback_attempted",
        message=f"Restarting Sentinel services for rollback to {previous_artifact['version']}.",
        job_logger=job_logger,
        phase_key="recovery",
        checkpoint_key="attempting_rollback",
    )
    restart_stack_services(previous_state, job_logger, version_override=previous_artifact["version"])
    wait_for_health(job_logger, expected_version=previous_artifact["version"])
    hotspot_warning = run_shared_hotspot_recovery(
        job_logger,
        context=f"rollback to {previous_artifact['version']}",
    )

    current_state = load_appliance_state()
    current_state["previousVersion"] = str(job.get("targetVersion", ""))
    current_state["currentVersion"] = previous_artifact["version"]
    current_state["lastKnownGoodVersion"] = previous_artifact["version"]
    current_state["lastAttemptedVersion"] = str(job.get("attemptedVersion") or job.get("targetVersion") or "")
    current_state["lastFailedVersion"] = str(job.get("attemptedVersion") or job.get("targetVersion") or "")
    save_appliance_state(current_state)
    update_runtime_version(previous_artifact["version"])

    job["currentVersion"] = previous_artifact["version"]
    job["lastKnownGoodVersion"] = previous_artifact["version"]
    job["lastFailedVersion"] = str(job.get("attemptedVersion") or job.get("targetVersion") or "")
    job["healthzPassed"] = True
    job["rollbackResult"] = "succeeded"
    job["rollback"]["result"] = "succeeded"
    job["rollback"]["currentVersion"] = previous_artifact["version"]
    job["restoreRecommended"] = False
    set_next_action(job, f"Review the update log and trace. Sentinel was rolled back to {previous_artifact['version']}.")
    if hotspot_warning is not None:
        record_warning(job, hotspot_warning)
        job["network"] = {"status": "degraded", "message": hotspot_warning}
    else:
        job["network"] = {"status": "ok", "message": "Rollback networking checks passed."}
    update_job(
        job,
        status="rolled_back",
        message=(
            f"Rollback completed to {previous_artifact['version']}."
            if hotspot_warning is None
            else (
                f"Rollback completed to {previous_artifact['version']}. "
                f"Host hotspot still needs attention: {hotspot_warning}"
            )
        ),
        job_logger=job_logger,
        finished=True,
        phase_key="recovery",
        checkpoint_key="rollback_completed",
    )
    trace("warning", f"Rollback completed successfully to {previous_artifact['version']}.")


def execute_update(job: dict[str, Any], job_logger: JobLogger) -> None:
    target_version = str(job.get("targetVersion", "")).strip()
    if not VERSION_PATTERN.match(target_version):
        raise UpdaterError("authorized", "Target version did not match the stable version contract.")

    current_version = current_version_from_env()
    if current_version is None:
        raise UpdaterError("authorized", "Current Sentinel version could not be determined.")
    current_state = load_appliance_state()
    runtime_state = build_runtime_state(current_state, job)
    trace(
        "info",
        f"Beginning update job {job.get('jobId')} from {current_version} to {target_version}.",
    )

    if compare_version_tags(target_version, current_version) <= 0:
        raise UpdaterError(
            "authorized",
            f"Target version {target_version} is not newer than the current version {current_version}.",
        )

    job["currentVersion"] = current_version
    job["previousVersion"] = current_version
    job["requestedVersion"] = target_version
    job["attemptedVersion"] = target_version
    job["lastKnownGoodVersion"] = str(current_state.get("lastKnownGoodVersion", current_version))
    job["lastFailedVersion"] = str(current_state.get("lastFailedVersion", ""))
    job["latestVersion"] = None
    job["healthzPassed"] = None
    job.setdefault("artifact", {})
    job.setdefault("backup", {"attempted": False, "succeeded": False, "paths": [], "manifests": []})
    job.setdefault("rollback", {"attempted": False, "result": "not_needed"})
    job.setdefault("migration", {"mode": "deploy", "status": "pending"})
    job.setdefault("network", {"status": "pending", "message": "Not started."})

    try:
        latest_release = fetch_latest_release()
    except UpdaterError as error:
        job_logger.write_line(
            "Latest release metadata lookup failed while authorizing the update. "
            f"Continuing with the explicit target {target_version}: {error}"
        )
        trace(
            "warning",
            "Latest release metadata lookup failed while authorizing "
            f"{target_version}; continuing with the explicit target. Reason: {error}",
        )
    else:
        job["latestVersion"] = normalize_version_tag(str(latest_release.get("tag_name", "")).strip())

    update_job(
        job,
        status="authorized",
        message=f"Update request for {target_version} was authorized.",
        job_logger=job_logger,
        phase_key="prepare_update",
        checkpoint_key="request_authorized",
    )

    update_job(
        job,
        status="staging",
        message="Creating a pre-update backup of Sentinel and Wiki.js.",
        job_logger=job_logger,
        phase_key="protect_current_system",
        checkpoint_key="creating_pre_update_backup",
    )
    backup_metadata = prepare_backup(job, job_logger)

    update_job(
        job,
        status="staging",
        message=f"Preparing rollback artifacts for {current_version}.",
        job_logger=job_logger,
        phase_key="protect_current_system",
        checkpoint_key="preparing_rollback_artifact",
    )
    previous_artifact: dict[str, str] | None = None
    try:
        previous_artifact = cache_verified_release(current_version, job_logger, purpose="rollback")
    except UpdaterError as error:
        job_logger.write_line(
            "Rollback artifact preparation was skipped for the current version "
            f"{current_version}: {error}"
        )
        record_warning(job, f"Rollback artifact preparation was skipped for {current_version}: {error}")
        job["rollback"]["result"] = "not_available"

    update_job(
        job,
        status="downloading",
        message=f"Downloading Sentinel release {target_version}.",
        job_logger=job_logger,
        phase_key="install_release",
        checkpoint_key="downloading_release",
    )
    target_artifact = cache_verified_release(target_version, job_logger, purpose="target release")
    run_update_disk_preflight(target_artifact=target_artifact, job_logger=job_logger)

    update_job(
        job,
        status="verifying",
        message=f"Verifying release checksums and manifests for {target_version}.",
        job_logger=job_logger,
        phase_key="install_release",
        checkpoint_key="verifying_release_artifacts",
    )
    job["artifact"] = {"target": target_artifact}
    target_manifest_path = write_artifact_manifest(
        target_artifact,
        job_id=str(job["jobId"]),
        purpose="target",
    )
    if target_manifest_path is not None:
        job["artifact"]["target"]["manifestPath"] = target_manifest_path
    if previous_artifact is not None:
        job["artifact"]["previous"] = previous_artifact
        previous_manifest_path = write_artifact_manifest(
            previous_artifact,
            job_id=str(job["jobId"]),
            purpose="rollback",
        )
        if previous_manifest_path is not None:
            job["artifact"]["previous"]["manifestPath"] = previous_manifest_path

    backup_output_dir = backup_metadata.get("outputDir")
    if isinstance(backup_output_dir, str) and backup_output_dir:
        output_dir = Path(backup_output_dir)
        backup_metadata["paths"] = [str(path) for path in sorted(output_dir.glob("*")) if path.is_file()]
        backup_metadata["manifests"] = [
            str(path) for path in sorted(output_dir.glob("*.manifest.json")) if path.is_file()
        ]
    job["backup"] = backup_metadata

    current_state["lastAttemptedVersion"] = target_version
    current_state["lastFailedVersion"] = ""
    save_appliance_state(current_state)
    persist_job(job)

    update_job(
        job,
        status="installing",
        message=f"Installing Sentinel package {target_version}.",
        job_logger=job_logger,
        phase_key="install_release",
        checkpoint_key="installing_package",
    )
    install_deb(Path(target_artifact["debPath"]), job_logger)

    update_job(
        job,
        status="post_install",
        message="Pulling updated container images.",
        job_logger=job_logger,
        phase_key="bring_services_back",
        checkpoint_key="pulling_container_images",
    )
    pull_stack_images(runtime_state, job_logger, version_override=target_version)

    update_job(
        job,
        status="restarting",
        message="Restarting Sentinel services.",
        job_logger=job_logger,
        phase_key="bring_services_back",
        checkpoint_key="restarting_services",
    )
    restart_stack_services(runtime_state, job_logger, version_override=target_version)

    update_job(
        job,
        status="health_check",
        message="Applying safe database migrations.",
        job_logger=job_logger,
        phase_key="verify_and_finalize",
        checkpoint_key="applying_database_migrations",
    )
    run_backend_post_update(job, runtime_state, job_logger, version_override=target_version)
    update_job(
        job,
        status="health_check",
        message="Waiting for Sentinel health checks to pass.",
        job_logger=job_logger,
        phase_key="verify_and_finalize",
        checkpoint_key="waiting_for_health_endpoint",
    )
    wait_for_health(job_logger, expected_version=target_version)
    job["healthzPassed"] = True
    job["migration"] = {"mode": "deploy", "status": "completed"}
    update_job(
        job,
        status="health_check",
        message="Checking hosted hotspot recovery.",
        job_logger=job_logger,
        phase_key="verify_and_finalize",
        checkpoint_key="recovering_hotspot",
    )
    hotspot_warning = run_shared_hotspot_recovery(
        job_logger,
        context=f"update to {target_version}",
    )

    current_state["withObs"] = bool(runtime_state.get("withObs", False))
    current_state["allowGrafanaLan"] = bool(runtime_state.get("allowGrafanaLan", False))
    current_state["allowWikiLan"] = bool(runtime_state.get("allowWikiLan", False))
    current_state["previousVersion"] = current_version
    current_state["currentVersion"] = target_version
    current_state["lastKnownGoodVersion"] = target_version
    current_state["lastAttemptedVersion"] = target_version
    current_state["lastFailedVersion"] = ""
    save_appliance_state(current_state)
    update_runtime_version(target_version)

    job["currentVersion"] = target_version
    job["lastKnownGoodVersion"] = target_version
    job["lastFailedVersion"] = ""
    job["rollbackResult"] = "not_needed"
    job["rollback"]["result"] = "not_needed"
    if hotspot_warning is not None:
        record_warning(job, hotspot_warning)
        job["network"] = {"status": "degraded", "message": hotspot_warning}
        set_next_action(job, "Review hotspot recovery details in the trace log.")
    else:
        job["network"] = {"status": "ok", "message": "Shared hotspot recovery completed cleanly."}
        set_next_action(job, "No action required.")
    update_job(
        job,
        status="completed",
        message=(
            f"Sentinel updated successfully to {target_version}."
            if hotspot_warning is None
            else (
                f"Sentinel updated successfully to {target_version}. "
                f"Host hotspot still needs attention: {hotspot_warning}"
            )
        ),
        job_logger=job_logger,
        finished=True,
        phase_key="verify_and_finalize",
        checkpoint_key="update_completed",
    )


def run_current_job() -> int:
    ensure_runtime_directories()
    lock_handle = LOCK_PATH.open("a+", encoding="utf-8")
    try:
        fcntl.flock(lock_handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        LOGGER.info("Another updater instance is already running.")
        trace("warning", "Another updater instance is already running; skipping duplicate invocation.")
        return 0

    job = load_job(CURRENT_JOB_PATH)
    if is_terminal_job(job):
        LOGGER.info("Current job %s is already terminal; nothing to do.", job.get("jobId"))
        trace("info", f"Current job {job.get('jobId')} is already terminal; nothing to do.")
        return 0

    if trace_session_matches_job(job):
        trace("info", f"Continuing active update trace for job {job.get('jobId')}.")
    else:
        archive_and_reset_trace(
            TRACE_COMPONENT,
            (
                "Re-synced the active update trace for "
                f"job {job.get('jobId')} targeting {job.get('targetVersion')}."
            ),
            archive_suffix=str(job.get("jobId", "")).strip() or TRACE_COMPONENT,
            session_job_id=str(job.get("jobId", "")).strip() or None,
        )

    job_logger = JobLogger(str(job["jobId"]))
    job["jobLogPath"] = str(job_logger.path)
    persist_job(job)

    try:
        execute_update(job, job_logger)
    except UpdaterError as error:
        failure_summary = sanitize_failure_summary(str(error))
        should_rollback = str(job.get("status", "")) in {"post_install", "restarting", "health_check"}
        attempted_version = str(job.get("attemptedVersion") or job.get("targetVersion") or "").strip()
        failure_state = load_appliance_state()
        if attempted_version:
            failure_state["lastAttemptedVersion"] = attempted_version
            failure_state["lastFailedVersion"] = attempted_version
            save_appliance_state(failure_state)
        job["healthzPassed"] = False
        job["migration"] = {
            "mode": "deploy",
            "status": "failed" if str(job.get("status", "")) == "health_check" else job.get("migration", {}).get("status", "pending"),
        }
        trace("error", f"Update job {job.get('jobId')} failed: {error}")
        if not should_rollback:
            set_next_action(job, "Inspect the update trace and correct the staging error before retrying.")
        update_job(
            job,
            status="failed",
            message=str(error),
            failure_summary=failure_summary,
            job_logger=job_logger,
            finished=not should_rollback,
            phase_key="recovery",
            checkpoint_key="update_failed",
        )

        if should_rollback:
            previous_artifact = job.get("artifact", {}).get("previous")
            if isinstance(previous_artifact, dict):
                try:
                    rollback(job, previous_artifact, job_logger)
                except Exception as rollback_error:  # noqa: BLE001
                    trace("error", f"Rollback failed for job {job.get('jobId')}: {rollback_error}")
                    job["rollbackResult"] = "failed"
                    job["rollback"]["result"] = "failed"
                    job["restoreRecommended"] = True
                    backup_paths = job.get("backup", {}).get("paths", [])
                    if isinstance(backup_paths, list) and backup_paths:
                        set_next_action(
                            job,
                            "Restore from the pre-update backup if needed: "
                            + ", ".join(str(path) for path in backup_paths),
                        )
                    else:
                        set_next_action(job, "Inspect the update trace and restore from the latest known good backup.")
                    update_job(
                        job,
                        status="rollback_attempted",
                        message=f"Rollback failed: {rollback_error}",
                        failure_summary=sanitize_failure_summary(str(rollback_error)),
                        job_logger=job_logger,
                        finished=True,
                        phase_key="recovery",
                        checkpoint_key="rollback_failed",
                    )
            else:
                trace(
                    "warning",
                    f"Rollback could not start for job {job.get('jobId')} because previous artifact metadata was unavailable.",
                )
                job["rollbackResult"] = "not_available"
                job["rollback"]["result"] = "not_available"
                job["restoreRecommended"] = True
                backup_paths = job.get("backup", {}).get("paths", [])
                if isinstance(backup_paths, list) and backup_paths:
                    set_next_action(
                        job,
                        "Rollback metadata was unavailable. Restore from the pre-update backup if needed: "
                        + ", ".join(str(path) for path in backup_paths),
                    )
                else:
                    set_next_action(
                        job,
                        "Rollback metadata was unavailable. Inspect the trace and restore from the latest known good backup if needed.",
                    )
                update_job(
                    job,
                    status="rollback_attempted",
                    message="Rollback could not start because the previous artifact metadata was unavailable.",
                    failure_summary="Rollback metadata was unavailable.",
                    job_logger=job_logger,
                    finished=True,
                    phase_key="recovery",
                    checkpoint_key="rollback_failed",
                )
        return 1
    finally:
        job_logger.close()

    trace("info", f"Update job {job.get('jobId')} completed successfully.")
    return 0


def show_job(path: Path) -> int:
    payload = read_json_file(path)
    if payload is None:
        print("null")
        return 1
    json.dump(payload, sys.stdout, indent=2, sort_keys=True)
    print()
    return 0


def iter_report_payloads(*, operation: str | None = None) -> list[dict[str, Any]]:
    reports: list[dict[str, Any]] = []
    seen_paths: set[Path] = set()
    for path in [CURRENT_JOB_PATH, *sorted(JOBS_DIR.glob("*.json"))]:
        if path in seen_paths or not path.exists():
            continue
        seen_paths.add(path)
        payload = read_json_file(path)
        if not isinstance(payload, dict):
            continue
        if operation is not None and str(payload.get("operation", "")).strip() != operation:
            continue
        reports.append(payload)
    reports.sort(key=sort_timestamp, reverse=True)
    return reports


def show_last_report(operation: str | None) -> int:
    reports = iter_report_payloads(operation=operation)
    if not reports:
        print("No matching updater report was found.")
        return 1
    return print_report_summary(reports[0])


def version_from_download_name(path: Path) -> str | None:
    match = re.fullmatch(r"sentinel_([0-9]+\.[0-9]+\.[0-9]+)_all\.deb", path.name)
    if match is None:
        return None
    return f"v{match.group(1)}"


def remove_path(path: Path, *, dry_run: bool) -> None:
    if dry_run:
        print(f"Would remove {path}")
        return
    if path.is_dir():
        shutil.rmtree(path, ignore_errors=True)
    else:
        path.unlink(missing_ok=True)


def prune_downloads(*, dry_run: bool) -> int:
    state = load_appliance_state()
    keep_versions = protected_versions(state)
    download_paths = sorted(DOWNLOADS_DIR.glob("sentinel_*_all.deb"))
    remaining_versions = sorted(
        {
            version
            for path in download_paths
            if (version := version_from_download_name(path)) is not None and version not in keep_versions
        },
        key=lambda value: tuple(int(part) for part in value.removeprefix("v").split(".")),
        reverse=True,
    )
    if remaining_versions:
        keep_versions.add(remaining_versions[0])

    removed = 0
    for path in download_paths:
        version = version_from_download_name(path)
        if version is None or version in keep_versions:
            continue
        checksum_path = DOWNLOADS_DIR / f"SHA256SUMS-{version.removeprefix('v')}.txt"
        manifest_path = path.with_suffix(path.suffix + ".manifest.json")
        remove_path(path, dry_run=dry_run)
        remove_path(checksum_path, dry_run=dry_run)
        remove_path(manifest_path, dry_run=dry_run)
        removed += 1
    return removed


def prune_logs(*, dry_run: bool) -> int:
    cutoff = utc_datetime() - timedelta(days=DEFAULT_PRUNE_KEEP_LOG_DAYS)
    removed = 0
    for path in sorted(LOG_ROOT.glob("system-update-*.log")):
        try:
            modified = datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc)
        except OSError:
            continue
        if modified < cutoff:
            remove_path(path, dry_run=dry_run)
            removed += 1
    return removed


def prune_traces(*, dry_run: bool) -> int:
    cutoff = utc_datetime() - timedelta(days=DEFAULT_PRUNE_KEEP_TRACE_DAYS)
    removed = 0
    for path in sorted(TRACE_ARCHIVE_DIR.glob("update-trace-*.log")):
        try:
            modified = datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc)
        except OSError:
            continue
        if modified < cutoff:
            remove_path(path, dry_run=dry_run)
            removed += 1

    for path in sorted(JOBS_DIR.glob("*.json")):
        payload = read_json_file(path)
        if not isinstance(payload, dict):
            continue
        finished_at = parse_timestamp(str(payload.get("finishedAt", "")))
        if finished_at is not None and finished_at < cutoff:
            remove_path(path, dry_run=dry_run)
            removed += 1
    return removed


def backup_entry_related_version(path: Path) -> str | None:
    manifest_candidates = [path] if path.is_file() and path.name.endswith(".manifest.json") else list(path.glob("*.manifest.json")) if path.is_dir() else []
    for manifest_path in manifest_candidates:
        payload = read_json_file(manifest_path)
        if not isinstance(payload, dict):
            continue
        version = payload.get("relatedVersion")
        if isinstance(version, str) and version.strip():
            return normalize_version_tag(version.strip())
    return None


def backup_entry_timestamp(path: Path) -> datetime:
    candidates = [path] if path.is_file() else [path]
    latest = datetime.fromtimestamp(0, tz=timezone.utc)
    for candidate in candidates:
        try:
            latest = max(latest, datetime.fromtimestamp(candidate.stat().st_mtime, tz=timezone.utc))
        except OSError:
            continue
    return latest


def backup_entry_key(path: Path) -> tuple[str, str]:
    timestamp = backup_entry_timestamp(path)
    return timestamp.date().isoformat(), f"{timestamp.isocalendar().year}-W{timestamp.isocalendar().week:02d}"


def prune_backups(*, dry_run: bool) -> int:
    keep_version = normalize_version_tag(str(load_appliance_state().get("currentVersion", "")))
    entries = [path for path in sorted(BACKUPS_DIR.iterdir()) if path.exists()]
    dated_entries = sorted(entries, key=backup_entry_timestamp, reverse=True)
    keep_paths: set[Path] = set()
    daily_seen: set[str] = set()
    weekly_seen: set[str] = set()
    monthly_seen: set[str] = set()

    for path in dated_entries:
        related_version = backup_entry_related_version(path)
        timestamp = backup_entry_timestamp(path)
        day_key, week_key = backup_entry_key(path)
        month_key = f"{timestamp.year}-{timestamp.month:02d}"
        if keep_version and related_version == keep_version:
            keep_paths.add(path)
            continue
        if len(daily_seen) < 7 and day_key not in daily_seen:
            keep_paths.add(path)
            daily_seen.add(day_key)
            continue
        if len(weekly_seen) < 4 and week_key not in weekly_seen:
            keep_paths.add(path)
            weekly_seen.add(week_key)
            continue
        if len(monthly_seen) < 3 and month_key not in monthly_seen:
            keep_paths.add(path)
            monthly_seen.add(month_key)
            continue

    removed = 0
    for path in dated_entries:
        if path in keep_paths:
            continue
        remove_path(path, dry_run=dry_run)
        removed += 1
    return removed


def run_prune(args: argparse.Namespace) -> int:
    ensure_runtime_directories()
    selected = {
        "downloads": args.downloads,
        "logs": args.logs,
        "traces": args.traces,
        "backups": args.backups,
    }
    if not any(selected.values()):
        selected = {key: True for key in selected}

    counts: dict[str, int] = {}
    if selected["downloads"]:
        counts["downloads"] = prune_downloads(dry_run=args.dry_run)
    if selected["logs"]:
        counts["logs"] = prune_logs(dry_run=args.dry_run)
    if selected["traces"]:
        counts["traces"] = prune_traces(dry_run=args.dry_run)
    if selected["backups"]:
        counts["backups"] = prune_backups(dry_run=args.dry_run)

    for key, value in counts.items():
        print(f"{key}: {value}")
    return 0


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Sentinel appliance updater")
    subparsers = parser.add_subparsers(dest="command", required=True)
    subparsers.add_parser("run-current-job")
    subparsers.add_parser("show-current-job")
    show_job_parser = subparsers.add_parser("show-job")
    show_job_parser.add_argument("job_id")
    enqueue_manual_parser = subparsers.add_parser("enqueue-manual-update")
    enqueue_manual_parser.add_argument("--version", required=True)
    with_obs_group = enqueue_manual_parser.add_mutually_exclusive_group()
    with_obs_group.add_argument("--with-obs", dest="with_obs", action="store_true")
    with_obs_group.add_argument("--without-obs", dest="with_obs", action="store_false")
    enqueue_manual_parser.set_defaults(with_obs=None)
    grafana_group = enqueue_manual_parser.add_mutually_exclusive_group()
    grafana_group.add_argument("--allow-grafana-lan", dest="allow_grafana_lan", action="store_true")
    grafana_group.add_argument("--disallow-grafana-lan", dest="allow_grafana_lan", action="store_false")
    enqueue_manual_parser.set_defaults(allow_grafana_lan=None)
    wiki_group = enqueue_manual_parser.add_mutually_exclusive_group()
    wiki_group.add_argument("--allow-wiki-lan", dest="allow_wiki_lan", action="store_true")
    wiki_group.add_argument("--disallow-wiki-lan", dest="allow_wiki_lan", action="store_false")
    enqueue_manual_parser.set_defaults(allow_wiki_lan=None)
    enqueue_manual_parser.add_argument("--requested-by", default=DEFAULT_MANUAL_REQUESTED_BY)
    enqueue_manual_parser.add_argument("--source", choices=["desktop", "cli", "auto-upgrade"], default="cli")
    show_last_report_parser = subparsers.add_parser("show-last-report")
    show_last_report_parser.add_argument("--operation", choices=["update", "rollback", "backup", "restore"])
    prune_parser = subparsers.add_parser("prune")
    prune_parser.add_argument("--downloads", action="store_true")
    prune_parser.add_argument("--logs", action="store_true")
    prune_parser.add_argument("--traces", action="store_true")
    prune_parser.add_argument("--backups", action="store_true")
    prune_parser.add_argument("--dry-run", action="store_true")
    return parser.parse_args()


def main() -> int:
    configure_logging()
    args = parse_args()
    if args.command == "enqueue-manual-update":
        return enqueue_manual_update(args)
    if args.command == "run-current-job":
        return run_current_job()
    if args.command == "show-current-job":
        return show_job(CURRENT_JOB_PATH)
    if args.command == "show-job":
        return show_job(JOBS_DIR / f"{args.job_id}.json")
    if args.command == "show-last-report":
        return show_last_report(args.operation)
    if args.command == "prune":
        return run_prune(args)
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
