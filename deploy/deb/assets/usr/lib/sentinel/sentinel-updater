def utc_datetime() -> datetime:
    return datetime.now(tz=timezone.utc)


def parse_timestamp(value: str | None) -> datetime | None:
    if value is None:
        return None
    try:
        return datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None


def duration_seconds(started_at: str | None, finished_at: str | None) -> int | None:
    started = parse_timestamp(started_at)
    finished = parse_timestamp(finished_at)
    if started is None or finished is None:
        return None
    return max(0, int((finished - started).total_seconds()))


def humanize_bytes(value: int) -> str:
    units = ["B", "KiB", "MiB", "GiB", "TiB"]
    size = float(max(value, 0))
    unit = units[0]
    for candidate in units:
        unit = candidate
        if size < 1024 or candidate == units[-1]:
            break
        size /= 1024
    if unit == "B":
        return f"{int(size)} {unit}"
    return f"{size:.1f} {unit}"


def sort_timestamp(payload: dict[str, Any]) -> datetime:
    for key in ("finishedAt", "startedAt", "requestedAt", "createdAt"):
        raw = payload.get(key)
        if isinstance(raw, str):
            parsed = parse_timestamp(raw)
            if parsed is not None:
                return parsed
    return datetime.fromtimestamp(0, tz=timezone.utc)


def record_warning(job: dict[str, Any], message: str) -> None:
    warnings = job.setdefault("warnings", [])
    if not isinstance(warnings, list):
        warnings = []
        job["warnings"] = warnings
    if message not in warnings:
        warnings.append(message)
    trace("warning", message)


