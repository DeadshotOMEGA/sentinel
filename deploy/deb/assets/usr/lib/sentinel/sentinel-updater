        "latestVersion": None,
        "targetVersion": target_version,
        "requestedVersion": target_version,
        "attemptedVersion": target_version,
        "previousVersion": current_version,
        "lastKnownGoodVersion": str(state.get("lastKnownGoodVersion", current_version)),
        "lastFailedVersion": str(state.get("lastFailedVersion", "")),
        "failureSummary": None,
        "rollbackAttempted": False,
        "rollbackResult": "not_needed",
        "restoreRecommended": False,
        "healthzPassed": None,
        "requestedBy": {
            "memberId": f"manual-{operation_source}",
            "memberName": requested_by,
            "accountLevel": None,
            "fromIp": None,
        },
        "requestedConfig": requested_config,
        "artifact": {},
        "backup": {"attempted": False, "succeeded": False, "paths": [], "manifests": []},
        "rollback": {"attempted": False, "result": "not_needed", "currentVersion": current_version},
        "migration": {"mode": None, "status": "pending"},
        "network": {"status": "pending", "message": "Not started."},
        "warnings": [],
        "phase": {
            "key": "prepare_update",
            "label": "Prepare update",
            "description": "Confirm the requested release and gather trusted metadata.",
            "kind": "primary",
            "order": 1,
            "total": 5,
        },
